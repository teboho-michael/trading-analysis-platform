# Trading Analysis Platform backend configuration template.
# Copy to .env on the Windows VPS and fill values there. Do not commit real values.

PORT=5000
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=trading_analysis
DB_USER=trading_app
DB_PASSWORD=replace-with-production-database-password
MT5_BRIDGE_SECRET=replace-with-shared-bridge-secret
MARKET_PROVIDER=broker_mt5

# Optional runtime controls.
SCAN_SCHEDULER_ENABLED=false
SCAN_CRON=*/5 * * * *
MT5_BRIDGE_URL=http://127.0.0.1:7001
MT5_BRIDGE_TIMEOUT_MS=10000
PROVIDER_REQUEST_DELAY_MS=10000
PROVIDER_MAX_RETRIES=2
PROVIDER_RETRY_DELAY_MS=60000
ACCOUNT_BALANCE=10000
RISK_PERCENT=1
H4_ZONE_LOOKBACK=220
CANDLE_RETENTION_LIMIT=300
MT5_TICK_FUTURE_TOLERANCE_SECONDS=60
MT5_TICK_SKEW_TOLERANCE_SECONDS=60
